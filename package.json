{
  "name": "react-daily-lab",
  "private": true,
  "version": "0.0.0",
  "description": "A React + Tailwind experiment lab for common daily frontend workflows.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "tsc -b && vite build --mode analyze",
    "lint": "eslint . --cache --cache-location .cache/eslint --cache-strategy content",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint --cache-strategy content",
    "lint:typed": "eslint . --config eslint.typed.config.js --cache --cache-location .cache/eslint-typed --cache-strategy content",
    "preview": "vite preview",
    "svg:optimize": "svgo -f ./src/assets/icons --config=./svgo.config.mjs"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.91.0",
    "@tanstack/react-virtual": "^3.13.23",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-plugin-svgr": "^4.5.0"
  }
}
